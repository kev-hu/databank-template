# Scraper output and runtime state — large, regenerable, machine-specific.
# Ignore the contents but keep the empty dirs (via .gitkeep) so the layout is
# visible on clone.
data/*
state/*
logs/*
!data/.gitkeep
!state/.gitkeep
!logs/.gitkeep

# Secrets — never commit. Read tokens from env vars (e.g. GITHUB_TOKEN).
*.local
.env

# Editor / OS noise
.DS_Store
*.swp
.vscode/
.idea/
__pycache__/
*.pyc
